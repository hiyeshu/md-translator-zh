{
	"name": "md-translator-zh",
	"displayName": "Markdown 中文翻译器",
	"description": "专业 Markdown 中文翻译工具。支持分栏预览、差异翻译、格式保护和多服务商接入。",
	"version": "1.0.3",
	"publisher": "hiyeshu",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/hiyeshu/md-translator-zh.git"
	},
	"bugs": {
		"url": "https://github.com/hiyeshu/md-translator-zh/issues"
	},
	"homepage": "https://github.com/hiyeshu/md-translator-zh",
	"engines": {
		"vscode": "^1.74.0"
	},
	"categories": [
		"Other",
		"Formatters",
		"Language Packs"
	],
	"keywords": [
		"markdown",
		"translator",
		"simplified-chinese",
		"简体中文",
		"zh-cn",
		"zh-hans",
		"chinese",
		"translation",
		"documentation",
		"i18n",
		"localization",
		"google-translate",
		"volcengine-translate",
		"split-pane",
		"delta-translation"
	],
	"activationEvents": [
		"onLanguage:markdown"
	],
	"main": "./out/extension.js",
	"browser": "./out/extension.js",
	"icon": "assets/icon.png",
	"contributes": {
		"commands": [
			{
				"command": "mdcarrot.openViewer",
				"title": "打开 Markdown 中文翻译器",
				"category": "Markdown 中文翻译器",
				"icon": "$(globe)"
			},
			{
				"command": "mdcarrot.testConnection",
				"title": "测试翻译服务连接",
				"category": "Markdown 中文翻译器"
			},
			{
				"command": "mdcarrot.clearCache",
				"title": "清除翻译缓存",
				"category": "Markdown 中文翻译器"
			},
			{
				"command": "mdcarrot.clearProviderCache",
				"title": "清除当前服务商缓存",
				"category": "Markdown 中文翻译器"
			},
			{
				"command": "mdcarrot.showCacheStats",
				"title": "显示缓存统计",
				"category": "Markdown 中文翻译器"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "mdcarrot.openViewer",
					"when": "resourceExtname == .md",
					"group": "navigation"
				}
			],
			"editor/context": [
				{
					"command": "mdcarrot.openViewer",
					"when": "resourceExtname == .md",
					"group": "navigation"
				}
			],
			"editor/title": [
				{
					"command": "mdcarrot.openViewer",
					"when": "resourceExtname == .md",
					"group": "navigation"
				}
			]
		},
		"keybindings": [
			{
				"command": "mdcarrot.openViewer",
				"key": "ctrl+shift+t",
				"mac": "cmd+shift+t"
			}
		],
		"configuration": {
			"title": "Markdown 中文翻译器",
			"properties": {
				"markdownTranslator.provider": {
					"type": "string",
					"default": "free",
					"order": 1,
					"enum": [
						"free",
						"volcengine",
						"google"
					],
					"enumDescriptions": [
						"实验性免费：Google 网页端点 + MyMemory",
						"火山引擎机器翻译",
						"Google Translate API"
					],
					"description": "选择翻译服务商"
				},
				"markdownTranslator.free.googleMirror": {
					"type": "string",
					"order": 2,
					"description": "免费 Google 镜像地址（可选）"
				},
				"markdownTranslator.google.apiKey": {
					"type": "string",
					"order": 3,
					"description": "Google Translate API Key（安全存储）",
					"scope": "machine"
				},
				"markdownTranslator.volcengine.accessKeyId": {
					"type": "string",
					"order": 4,
					"description": "火山引擎 AccessKeyId",
					"scope": "machine"
				},
				"markdownTranslator.volcengine.secretKey": {
					"type": "string",
					"order": 5,
					"description": "火山引擎 SecretKey",
					"scope": "machine"
				},
				"markdownTranslator.volcengine.region": {
					"type": "string",
					"default": "cn-north-1",
					"order": 6,
					"description": "火山引擎区域"
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "npx @vscode/vsce package --out dist/",
		"prepackage": "npm run compile",
		"clean": "rm -rf out dist/*.vsix",
		"release": "npm version patch && npm run package && npx ovsx publish dist/*.vsix -p $OVSX_TOKEN",
		"release:minor": "npm version minor && npm run package && npx ovsx publish dist/*.vsix -p $OVSX_TOKEN"
	},
	"devDependencies": {
		"@types/node": "16.x",
		"@types/vscode": "^1.74.0",
		"typescript": "^4.9.4"
	},
	"__metadata": {
		"installedTimestamp": 1777046209243,
		"targetPlatform": "universal",
		"size": 144061
	}
}
